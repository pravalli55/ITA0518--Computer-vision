import numpy as np
import matplotlib.pyplot as plt

# -----------------------------
# Create a synthetic scene
# -----------------------------
h, w = 256, 256

scene = np.zeros((h, w, 3), dtype=np.float32)

# Sky
scene[:, :, :] = [0.1, 0.1, 0.25]

# Road
scene[150:256, :] = [0.25, 0.25, 0.25]

# Street lights
Y, X = np.ogrid[:h, :w]

lights = [(60, 60), (70, 180), (100, 120)]

for y, x in lights:
    mask = (X - x) ** 2 + (Y - y) ** 2 < 400
    scene[mask] = [1, 1, 0.7]

# -----------------------------
# Step 1: Low-light capture
# -----------------------------
low_light = scene * 0.2

# -----------------------------
# Step 2: Photon (Shot) Noise
# -----------------------------
shot_noise = np.random.poisson(low_light * 255) / 255.0

# -----------------------------
# Step 3: Sensor Read Noise
# -----------------------------
sensor_noise = shot_noise + np.random.normal(0, 0.03, shot_noise.shape)

# -----------------------------
# Step 4: ISO Amplification
# -----------------------------
gain = 5
digital_image = sensor_noise * gain

# Clip pixel values
digital_image = np.clip(digital_image, 0, 1)

# -----------------------------
# Display Results
# -----------------------------
titles = [
    "Original Scene",
    "Low-Light Scene",
    "Shot Noise",
    "Sensor Noise",
    "Final Digital Image"
]

images = [
    scene,
    low_light,
    np.clip(shot_noise, 0, 1),
    np.clip(sensor_noise, 0, 1),
    digital_image
]

plt.figure(figsize=(16,4))

for i in range(5):
    plt.subplot(1,5,i+1)
    plt.imshow(images[i])
    plt.title(titles[i], fontsize=10)
    plt.axis("off")

plt.tight_layout()
plt.show()
