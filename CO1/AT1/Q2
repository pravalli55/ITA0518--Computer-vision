import cv2
import numpy as np
import matplotlib.pyplot as plt

# -----------------------------
# Load image (replace with your image path)
# -----------------------------
# Use the name of your uploaded image file
image_file_name = "Screenshot 2026-07-22 102039.png"
image = cv2.imread(image_file_name)

if image is None:
    raise FileNotFoundError(f"Image not found. Please ensure '{image_file_name}' was uploaded correctly.")

image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)
image = image.astype(np.float32) / 255.0

# -----------------------------
# Step 1: Simulate low-light scene
# -----------------------------
light_factor = 0.15     # 15% brightness
low_light = image * light_factor

# -----------------------------
# Step 2: Simulate Photon (Shot) Noise
# -----------------------------
shot_noise = np.random.poisson(low_light * 255) / 255.0

# -----------------------------
# Step 3: Add Sensor Read Noise
# -----------------------------
read_noise = np.random.normal(0, 0.02, shot_noise.shape)

sensor_output = shot_noise + read_noise

# -----------------------------
# Step 4: ISO Amplification (Gain)
# -----------------------------
gain = 6

amplified = sensor_output * gain

# -----------------------------
# Step 5: Clip values to valid range
# -----------------------------
final_image = np.clip(amplified, 0, 1)

# -----------------------------
# Display Results
# -----------------------------
titles = ["Original Image",
          "Low-Light Scene",
          "After Shot Noise",
          "After Sensor Noise",
          "Final Digital Image"]

images = [image,
          low_light,
          shot_noise,
          sensor_output,
          final_image]

plt.figure(figsize=(18,6))

for i in range(5):
    plt.subplot(1,5,i+1)
    plt.imshow(images[i])
    plt.title(titles[i])
    plt.axis("off")

plt.tight_layout()
plt.show()

from google.colab import files
